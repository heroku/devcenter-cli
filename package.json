{
  "name": "@heroku-cli/plugin-devcenter",
  "description": "Heroku CLI plugin to interact with Heroku Dev Center",
  "version": "2.0.0",
  "author": "Heroku",
  "type": "module",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/heroku/devcenter-cli.git"
  },
  "bugs": "https://github.com/heroku/devcenter-cli/issues",
  "homepage": "https://github.com/heroku/devcenter-cli",
  "keywords": [
    "heroku-plugin",
    "oclif"
  ],
  "files": [
    "dist",
    "oclif.manifest.json"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "oclif": {
    "bin": "heroku",
    "commands": "./dist/commands",
    "devPlugins": [
      "@oclif/plugin-help"
    ],
    "topics": {
      "devcenter": {
        "description": "interact with Heroku Dev Center"
      }
    }
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run clean && tsc && oclif manifest && oclif readme",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "npm run build",
    "posttest": "npm run lint",
    "pretest": "npm run build",
    "readme": "oclif readme",
    "test": "vitest run --coverage",
    "version": "oclif readme && git add README.md"
  },
  "dependencies": {
    "@heroku-cli/command": "^12.4.1",
    "@heroku/heroku-cli-util": "^10.8.0",
    "@oclif/core": "^4.0.0",
    "cheerio": "^1.2.0",
    "chokidar": "^5.0.0",
    "debug": "^4.4.3",
    "express": "^5.2.1",
    "markdown-it": "^14.1.1",
    "markdown-it-anchor": "^9.2.0",
    "open": "^11.0.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@heroku-cli/test-utils": "^0.3.0",
    "@oclif/plugin-help": "^6.2.36",
    "@types/debug": "^4.1.12",
    "@types/express": "^5.0.6",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.15.3",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.8",
    "ansis": "^3.17.0",
    "eslint": "^9.39.4",
    "eslint-config-oclif": "^6.0.156",
    "eslint-plugin-vitest": "^0.5.4",
    "nock": "^14.0.12",
    "oclif": "^4.23.14",
    "sinon": "^21.0.3",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.8"
  }
}
