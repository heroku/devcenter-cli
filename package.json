{
  "name": "@heroku-cli/heroku-cli-plugin-devcenter",
  "description": "Heroku CLI plugin to interact with Heroku Dev Center",
  "version": "1.3.1",
  "author": "Heroku",
  "type": "module",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/heroku/devcenter-cli.git"
  },
  "bugs": "https://github.com/heroku/devcenter-cli/issues",
  "homepage": "https://github.com/heroku/devcenter-cli",
  "keywords": [
    "heroku-plugin",
    "oclif"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "oclif": {
    "bin": "heroku",
    "commands": "./dist/commands",
    "devPlugins": [
      "@oclif/plugin-help"
    ],
    "topics": {
      "devcenter": {
        "description": "interact with Heroku Dev Center"
      }
    }
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "npm run clean && tsc && oclif manifest && mv oclif.manifest.json ./dist/oclif.manifest.json",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "npm run build",
    "posttest": "npm run lint",
    "pretest": "npm run build",
    "test": "mocha --forbid-only \"test/**/*.test.ts\""
  },
  "dependencies": {
    "@heroku-cli/command": "^12.2.0",
    "@inquirer/prompts": "^8.4.1",
    "@oclif/core": "^4.3.0",
    "cheerio": "^1.2.0",
    "chokidar": "^5.0.0",
    "express": "^5.2.1",
    "markdown-it": "^14.1.1",
    "markdown-it-anchor": "^9.2.0",
    "netrc-parser": "3.1.6",
    "open": "^11.0.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@oclif/plugin-help": "^6.2.36",
    "@types/chai": "^5.2.3",
    "@types/express": "^5.0.6",
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.15.3",
    "@types/supertest": "^7.2.0",
    "ansis": "^3.17.0",
    "chai": "^6.2.2",
    "eslint": "^9.39.4",
    "eslint-config-oclif": "^6.0.156",
    "eslint-plugin-mocha": "^11.2.0",
    "mocha": "^11.7.5",
    "nock": "^14.0.12",
    "oclif": "^4.22.81",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.3"
  }
}
